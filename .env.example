# Database Configuration
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB_NAME=spkia
JOB_TTL_HOURS=24

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=your-secret-key-here-change-in-production

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# ML Model Configuration
MODEL_PATH=/app/models
ENSEMBLE_THRESHOLD=0.7
CNN_MODEL_VERSION=v1.0
PRNU_MODEL_VERSION=v1.0

# C2PA Configuration
C2PA_TRUST_ANCHORS_PATH=/app/trust_anchors
C2PA_VALIDATION_STRICT=true

# Sensor-PKI Configuration
SENSOR_PKI_TRUST_ANCHORS_PATH=/app/sensor_pki_anchors
SENSOR_PKI_ENABLE=true

# Security
MAX_UPLOAD_SIZE_MB=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis (for future caching/queue implementation)
REDIS_URL=redis://redis:6379
